AWS_REGION=ap-northeast-1
S3_BUCKET=
CLOUDFRONT_BASE_URL=

# CloudFront origin path is /public, so public URLs omit the S3 "public/" prefix.
CLOUDFRONT_PUBLIC_PATH_PREFIX=

# Configure these as Firebase Functions secrets, not plain env vars:
# firebase functions:secrets:set AWS_ACCESS_KEY_ID
# firebase functions:secrets:set AWS_SECRET_ACCESS_KEY
